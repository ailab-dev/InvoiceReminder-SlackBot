# Slack App（api.slack.com で取得）
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Upstash Redis（Upstash ダッシュボードで取得）
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# 認証トークン（自分でランダム文字列を生成: openssl rand -hex 32 など）
CRON_SECRET=your-random-secret-string

# 専用チャンネルの ID（Slack でチャンネル詳細を表示→末尾の C から始まる文字列）
REMINDER_CHANNEL_ID=C12345678

# フェーズ2: インターン給与管理
MANAGER_SLACK_ID=U12345678
INTERN_SALARY_CHANNEL_ID=C87654321
COMPANY_NAME=株式会社AilaB

# Redis に保存する個人情報（口座・電話・住所）の暗号化キー（AES-256-GCM）
# 生成コマンド: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-string

# フェーズ2: Google Drive（請求書PDF保存先）
GOOGLE_SERVICE_ACCOUNT_EMAIL=bot@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id
